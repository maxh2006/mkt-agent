# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file to .env on the server (at /opt/mkt-agent/.env).
# Never commit .env — it is in .gitignore.
#
# To generate AUTH_SECRET:
#   openssl rand -base64 32

# PostgreSQL connection string (Neon or any managed Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth secret — must be a long random string
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Required when running behind a reverse proxy or Cloudflare
AUTH_TRUST_HOST="true"

# Node environment
NODE_ENV="production"

# ─── Shared BigQuery Dataset (platform team) ────────────────────────────────
# Provided by platform team. See docs/04-automations.md.
#
# We reuse the existing mktagent-493404 GCP project — no new project needed.
# The service account is created inside mktagent-493404 and granted
# roles/bigquery.dataViewer on shared.* by the platform team.
# Query execution billing goes to mktagent-493404 (auto from SA credentials).
BQ_PLATFORM_PROJECT_ID=""        # Platform team's GCP project ID (where shared.* lives)
BQ_DATASET="shared"              # Dataset name (always "shared")
BQ_SERVICE_ACCOUNT_EMAIL=""      # e.g. mkt-agent-bq@mktagent-493404.iam.gserviceaccount.com
# GOOGLE_APPLICATION_CREDENTIALS path for the JSON key is set only when
# the actual query layer is implemented (later task).

# ─── Manus publishing worker ────────────────────────────────────────────────
# Dispatcher handoff. If MANUS_AGENT_ENDPOINT is unset the handoff runs in
# dry-run mode (logs payload, does not call out).
MANUS_AGENT_ENDPOINT=""          # e.g. https://manus.example.com/agent/dispatch
MANUS_API_KEY=""                 # Bearer token sent as Authorization header (optional)
# Shared secret for POST /api/jobs/dispatch (required to run the dispatcher).
# Cron should send it as header: x-dispatch-secret: <value>
MANUS_DISPATCH_SECRET=""         # generate with: openssl rand -base64 32
# Shared secret for POST /api/manus/callback (required to accept Manus results).
# Manus signs the raw request body with HMAC-SHA256 and sends it as header:
#   x-manus-signature: sha256=<hex-digest>
# Route returns 503 if this is unset and 401 on invalid signature.
MANUS_WEBHOOK_SECRET=""          # generate with: openssl rand -base64 32

# ─── AI content generator ───────────────────────────────────────────────────
# Provider for the text-generation client at src/lib/ai/client.ts.
#   stub       → dry-run stub; returns deterministic placeholder samples.
#                Safe default. No external API calls, no cost.
#   anthropic  → (future) call Claude via @anthropic-ai/sdk.
#   openai     → (future) call OpenAI via @openai/sdk.
# Image generation model is NOT locked in Phase 4 — the client always
# emits an `image_prompt` string; actual image rendering is a separate task.
AI_PROVIDER="stub"

# Gates the admin-only POST /api/ai/generate-from-fixture dev endpoint so
# it can't silently create fixture-driven drafts on a real brand. Flip to
# "true" only on dev/staging; leave unset (or "false") in prod.
ALLOW_AI_FIXTURES="false"
