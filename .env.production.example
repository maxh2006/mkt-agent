# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file to .env on the server (at /opt/mkt-agent/.env).
# Never commit .env — it is in .gitignore.
#
# To generate AUTH_SECRET:
#   openssl rand -base64 32

# PostgreSQL connection string (Neon or any managed Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth secret — must be a long random string
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Required when running behind a reverse proxy or Cloudflare
AUTH_TRUST_HOST="true"

# Node environment
NODE_ENV="production"

# ─── Shared BigQuery Dataset (platform team) ────────────────────────────────
# See docs/bq-shared-schema.md for the full cheat sheet, billing rule,
# and verified example queries.
#
# BILLING RULE: BigQuery charges the project that RUNS the query, not the
# project that OWNS the data. Every query MUST run under mktagent-493404
# (our billing project), never newgen-492518 (the data-owning project).
# src/lib/bq/client.ts pins this at construction so callers can't forget.
#
# Data-owning project : newgen-492518   (Newgen platform team)
# Billing project     : mktagent-493404 (us)
# Dataset             : shared
# Service account     : mkt-agent-bq@mktagent-493404.iam.gserviceaccount.com
# Refresh cadence     : hourly (Asia/Seoul)
# Granted role        : roles/bigquery.dataViewer on newgen-492518:shared
#
# Local dev: SA impersonation. Set the env below; src/lib/bq/client.ts
# picks it up and impersonates via google-auth-library's Impersonated.
# Requires roles/iam.serviceAccountTokenCreator on the target SA for your
# user + iamcredentials.googleapis.com API enabled on mktagent-493404.
BQ_IMPERSONATE_SA=""             # e.g. mkt-agent-bq@mktagent-493404.iam.gserviceaccount.com

# Prod (Compute Engine VM): leave BQ_IMPERSONATE_SA UNSET. Attach
# mkt-agent-bq@mktagent-493404.iam.gserviceaccount.com to the VM as its
# runtime service account — the SDK picks it up via metadata auth
# automatically. No key file on disk. (Follow-up task — not yet wired.)

# ─── Manus publishing worker ────────────────────────────────────────────────
# Dispatcher handoff. If MANUS_AGENT_ENDPOINT is unset the handoff runs in
# dry-run mode (logs payload, does not call out).
MANUS_AGENT_ENDPOINT=""          # e.g. https://manus.example.com/agent/dispatch
MANUS_API_KEY=""                 # Bearer token sent as Authorization header (optional)
# Shared secret for POST /api/jobs/dispatch (required to run the dispatcher).
# Cron should send it as header: x-dispatch-secret: <value>
MANUS_DISPATCH_SECRET=""         # generate with: openssl rand -base64 32
# Shared secret for POST /api/manus/callback (required to accept Manus results).
# Manus signs the raw request body with HMAC-SHA256 and sends it as header:
#   x-manus-signature: sha256=<hex-digest>
# Route returns 503 if this is unset and 401 on invalid signature.
MANUS_WEBHOOK_SECRET=""          # generate with: openssl rand -base64 32

# ─── AI content generator ───────────────────────────────────────────────────
# Provider for the text-generation client at src/lib/ai/client.ts.
#   stub       → dry-run stub; returns deterministic placeholder samples.
#                Safe default. No external API calls, no cost.
#   anthropic  → real Claude text generation via @anthropic-ai/sdk.
#                Requires ANTHROPIC_API_KEY (below). Fails loud if key
#                is unset — no silent fallback to stub.
# Image generation is explicitly deferred — the client always emits an
# `image_prompt` string; actual image rendering is a separate task.
AI_PROVIDER="stub"

# Anthropic Claude credentials (only read when AI_PROVIDER=anthropic).
# Get a key at https://console.anthropic.com/. The key is never logged.
ANTHROPIC_API_KEY=""
# Optional — defaults to claude-sonnet-4-6 (balanced quality/cost).
# Override for cheaper runs (e.g. claude-haiku-4-5-20251001) or richer
# output (e.g. claude-opus-4-7).
ANTHROPIC_MODEL=""

# Gates the admin-only POST /api/ai/generate-from-fixture dev endpoint so
# it can't silently create fixture-driven drafts on a real brand. Flip to
# "true" only on dev/staging; leave unset (or "false") in prod.
ALLOW_AI_FIXTURES="false"

# Gates the admin-only POST /api/promotions/fetch-preview dev endpoint
# that returns the raw PromoAdapterResult for a given brand. Handy for
# verifying upstream promo integration config on a fresh brand. Flip to
# "true" only on dev/staging; leave unset (or "false") in prod.
ALLOW_ADMIN_PROMO_PREVIEW="false"

# Gates the admin-only BQ adapter preview routes:
#   POST /api/big-wins/fetch-preview  → raw BigWinAdapterResult
#   POST /api/hot-games/fetch-preview → raw HotGamesAdapterResult
# Single shared flag keeps both dev routes off in prod by default. Flip
# to "true" only on dev/staging when exercising the adapters against
# real brand data. CLI scripts (npm run big-wins:preview /
# hot-games:preview) bypass this gate — operator's shell already
# authenticates via BQ_IMPERSONATE_SA.
ALLOW_ADMIN_BQ_PREVIEW="false"
