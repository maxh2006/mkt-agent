# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file to .env on the server (at /opt/mkt-agent/.env).
# Never commit .env — it is in .gitignore.
#
# To generate AUTH_SECRET:
#   openssl rand -base64 32

# PostgreSQL connection string (Neon or any managed Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth secret — must be a long random string
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Required when running behind a reverse proxy or Cloudflare
AUTH_TRUST_HOST="true"

# Node environment
NODE_ENV="production"

# ─── Shared BigQuery Dataset (platform team) ────────────────────────────────
# Provided by platform team. See docs/04-automations.md.
#
# We reuse the existing mktagent-493404 GCP project — no new project needed.
# The service account is created inside mktagent-493404 and granted
# roles/bigquery.dataViewer on shared.* by the platform team.
# Query execution billing goes to mktagent-493404 (auto from SA credentials).
BQ_PLATFORM_PROJECT_ID=""        # Platform team's GCP project ID (where shared.* lives)
BQ_DATASET="shared"              # Dataset name (always "shared")
BQ_SERVICE_ACCOUNT_EMAIL=""      # e.g. mkt-agent-bq@mktagent-493404.iam.gserviceaccount.com
# GOOGLE_APPLICATION_CREDENTIALS path for the JSON key is set only when
# the actual query layer is implemented (later task).
